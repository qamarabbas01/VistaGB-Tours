# Public site URL (used for sitemap, robots, Open Graph)
NEXT_PUBLIC_SITE_URL=https://vista-gb-tours.vercel.app

# Resend — required for the contact form
RESEND_API_KEY=re_xxxxxxxx
# Must be a verified sender/domain in Resend
RESEND_FROM_EMAIL=VistaGB Tours <onboarding@resend.dev>

# Optional inbox override (defaults to src/config/contact.ts email)
CONTACT_EMAIL_TO=you@example.com
